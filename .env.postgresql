# PostgreSQL Environment Configuration
# Copy this to .env when using PostgreSQL

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentic_trading
DB_USERNAME=trading_user
DB_PASSWORD=trading_password

# Spring Profile
SPRING_PROFILES_ACTIVE=postgresql

# Application Configuration
SERVER_PORT=8080

# OpenAI Configuration (keep existing values)
OPENAI_API_KEY=

# Market Data Configuration (keep existing values)
ALPHA_VANTAGE_API_KEY=demo
POLYGON_API_KEY=

# Push Notifications (keep existing values)
PUSHOVER_USER=
PUSHOVER_TOKEN=

# PostgreSQL Admin
PGADMIN_EMAIL=admin@trading.local
PGADMIN_PASSWORD=admin123