# Agents-pod-local environment variables.
#
# This file documents the variables the Python agents container reads when run
# OUTSIDE of docker-compose (e.g., `cd agents && uv run python main.py` against
# a backend running on the host or in another stack). The compose-managed run
# uses the repo-root `.env.example` — see the comments there.
#
# Copy to `.env` in this directory and fill in every required value.

# ---------------------------------------------------------------------------
# Required: agent LLM and research
# ---------------------------------------------------------------------------

OPENAI_API_KEY=
BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# Required: backend admin credentials for JWT login
# ---------------------------------------------------------------------------
#
# State-changing backend endpoints (POST /api/runs, POST /api/accounts/.../
# trades, etc.) are gated behind @PreAuthorize("hasRole('ADMIN')"). The agents
# pod POSTs these to /api/auth/login at startup, caches the returned JWT, and
# attaches `Authorization: Bearer <jwt>` on every backend call. On a 401 the
# token is refreshed once; a second 401 fails loudly.
#
# Must match the backend's configured admin user (the `admin/$ADMIN_PASSWORD`
# pair the backend's InMemoryUserDetailsManager bootstraps from
# SecurityConfig.userDetailsService).
BACKEND_ADMIN_USERNAME=admin
BACKEND_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Optional: backend wiring
# ---------------------------------------------------------------------------

# URL of the Java backend service. Defaults to the docker-compose service
# name; override for a host-side backend.
# BACKEND_URL=http://backend-service:8080
