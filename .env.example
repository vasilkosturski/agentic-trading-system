# Agentic Trading System — environment variables for local development.
#
# Usage:
#   1. Copy this file to `.env` in this same directory.
#   2. Fill in every value in the "Required" sections below — `docker compose up`
#      will refuse to start if any required variable is missing or empty.
#   3. Run `docker compose up --build` from this directory.
#
# `.env` (and `.env*` backups) are gitignored — do not commit your filled-in copy.

# ---------------------------------------------------------------------------
# Required: agent LLM and research
# ---------------------------------------------------------------------------

# OpenAI API key — drives the Market Analyst and Decision Maker agents.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Brave Search API key — backs the Brave Search MCP server the agents use for web research.
# Free tier (2,000 queries/month) is more than enough for local development.
# Sign up at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# Required: database
# ---------------------------------------------------------------------------

# Postgres password for the `trading_user` account. Used by the postgres container
# at first-boot to initialise the role, and by the backend + agents to connect.
# Pick any non-empty string — there is no `admin/admin`-style fallback; an empty
# value makes docker compose refuse to start.
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Required: login auth
# ---------------------------------------------------------------------------
#
# All three values are mandatory — the compose stack no longer ships local-dev
# fallbacks (`admin/admin`, placeholder JWT secret) because `docker compose up`
# off the README would otherwise boot with publicly-known credentials.

# JWT signing secret. Must be at least 32 characters for HS256 (the backend's
# JwtTokenProvider rejects shorter values at startup). Generate one with e.g.
# `openssl rand -base64 48`.
JWT_SECRET=

# Admin account password for the bootstrap admin user. Any non-empty string works
# locally; for anything reachable from outside localhost, pick something strong.
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Optional: market data
# ---------------------------------------------------------------------------

# Finnhub.io API key — real-time stock quotes for the backend's price cache.
# Without it, certain price-dependent endpoints fall back to cached or mock data.
# Free tier (60 calls/min) is sufficient for a single-user local stack.
# Sign up at: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ---------------------------------------------------------------------------
# Optional: login auth overrides
# ---------------------------------------------------------------------------
#
# JWT_SECRET and ADMIN_PASSWORD live in the "Required" sections above — no
# default fallbacks. The two below have safe defaults in docker-compose.yml
# (`admin` username, 1h token lifetime); override only if you want non-default
# values in your local instance.

# JWT_EXPIRATION=3600000
# ADMIN_USERNAME=admin

# ---------------------------------------------------------------------------
# Optional: cycle cadence
# ---------------------------------------------------------------------------

# How often the agents container runs a trading cycle (minutes).
# Default in docker-compose.yml is 480 (8h) — lower it for active testing.
# RUN_EVERY_N_MINUTES=60
