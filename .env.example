# Agentic Trading System Environment Variables
# Copy this file to .env and fill in your actual API keys

# OpenAI API (for trading agents) - REQUIRED
OPENAI_API_KEY=your_openai_api_key_here

# Market Data API (Polygon.io) - OPTIONAL
POLYGON_API_KEY=your_polygon_api_key_here

# Web Search API (Brave Search) - OPTIONAL
BRAVE_API_KEY=your_brave_api_key_here

# Push Notifications (Pushover) - OPTIONAL
PUSHOVER_TOKEN=your_pushover_token_here
PUSHOVER_USER=your_pushover_user_key_here

# Database Configuration (already set in docker-compose.yml)
# POSTGRES_DB=agentic_trading
# POSTGRES_USER=trading_user
# POSTGRES_PASSWORD=trading_password

# Additional Market Data APIs (OPTIONAL)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here