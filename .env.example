# Agentic Trading System — environment variables for local development.
#
# Usage:
#   1. Copy this file to `.env` in this same directory.
#   2. Fill in the values below — at minimum OPENAI_API_KEY and BRAVE_API_KEY,
#      the agents container will exit at startup without them.
#   3. Run `docker compose up --build` from this directory.
#
# `.env` is gitignored — do not commit your filled-in copy.

# ---------------------------------------------------------------------------
# Required: agent LLM and research
# ---------------------------------------------------------------------------

# OpenAI API key — drives the Market Analyst and Decision Maker agents.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Brave Search API key — backs the Brave Search MCP server the agents use for web research.
# Free tier (2,000 queries/month) is more than enough for local development.
# Sign up at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# Optional: market data
# ---------------------------------------------------------------------------

# Finnhub.io API key — real-time stock quotes for the backend's price cache.
# Without it, certain price-dependent endpoints fall back to cached or mock data.
# Free tier (60 calls/min) is sufficient for a single-user local stack.
# Sign up at: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ---------------------------------------------------------------------------
# Optional: login auth overrides
# ---------------------------------------------------------------------------
#
# The compose file ships safe local-dev defaults for all four of these
# (admin/admin, a placeholder JWT secret, 1h expiration). Override only if you
# want non-default credentials in your local instance.

# JWT_SECRET=
# JWT_EXPIRATION=3600000
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Optional: cycle cadence
# ---------------------------------------------------------------------------

# How often the agents container runs a trading cycle (minutes).
# Default in docker-compose.yml is 480 (8h) — lower it for active testing.
# RUN_EVERY_N_MINUTES=60
