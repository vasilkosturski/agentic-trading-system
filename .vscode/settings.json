{
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.fixAll.ruff": "explicit",
        "source.organizeImports.ruff": "explicit"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true
    },
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[java]": {
        "editor.formatOnSave": false
    },
    "eslint.workingDirectories": [
        { "pattern": "frontend" }
    ],
    "eslint.validate": ["typescript", "typescriptreact"],
    "java.jdt.ls.lombokSupport.enabled": true,
    "java.configuration.updateBuildConfiguration": "interactive",
    "java.compile.nullAnalysis.mode": "automatic",
    "java.eclipse.downloadSources": true,
    "java.maven.downloadSources": true,
    "java.gradle.downloadSources": true,
    "java.sources.organizeImports.starThreshold": 99,
    "java.sources.organizeImports.staticStarThreshold": 99,
    "java.completion.enabled": true,
    "java.completion.overwrite": true,
    "java.completion.guessMethodArguments": true,
    "java.signatureHelp.enabled": true,
    "java.contentProvider.preferred": "fernflower",
    "java.import.gradle.enabled": true,
    "java.import.gradle.wrapper.enabled": true,
    "java.import.gradle.java.home": null,
    "java.import.gradle.offline.enabled": false,
    "java.import.gradle.arguments": "",
    "java.import.gradle.jvmArguments": "",
    "java.import.gradle.user.home": null,
    "java.project.sourcePaths": [
        "backend/src/main/java"
    ],
    "java.project.outputPath": "backend/build/classes",
    "java.project.referencedLibraries": [
        "backend/build/libs/**/*.jar"
    ],
    "java.codeGeneration.insertionLocation": "afterCursor",
    "java.codeGeneration.generateComments": true,
    "java.codeGeneration.useBlocks": true,
    "java.saveActions.organizeImports": true,
    "java.format.enabled": true,
    "java.format.onType.enabled": true,
    "java.format.settings.url": null,
    "java.format.settings.profile": null,
    "java.checkstyle.configuration": "${workspaceFolder}/backend/config/checkstyle/checkstyle.xml",
    "java.checkstyle.version": "10.17.0",
    "files.exclude": {
        "**/build": true,
        "**/.gradle": true,
        "**/node_modules": true,
        "**/.git": true,
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.mypy_cache": true,
        "**/*.pyc": true
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/agents/venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "agents/tests",
        "-v",
        "--tb=short"
    ],
    "python.testing.cwd": "${workspaceFolder}/agents",
    "python.testing.autoTestDiscoverOnSaveEnabled": true
}
