# Node — must be ignored or the 400MB local install ships as build context
# (and on macOS contains darwin-arm64 native binaries that break the tar).
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (rebuilt inside the image)
dist/
build/
.vite/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docs
README.md
*.md

# Env (compose injects what the container needs)
.env
.env.local
.env.*.local

# Tests / coverage
coverage/
*.log
